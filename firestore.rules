rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'joao.faria@logcomex.com',
        'christian.bertolino@logcomex.com',
        'henrique.silva@logcomex.com',
        'adriano.martins@logcomex.com',
        'daniel.alle@logcomex.com'
      ];
    }
    function isViewer() {
      return request.auth != null && request.auth.token.email in [
        'leandro.oliveira@logcomex.com'
      ];
    }
    match /tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.auth.token.email == resource.data.email ||
        request.auth.token.email == resource.data.userEmail ||
        isAdmin() || isViewer()
      );
      allow update: if isAdmin() || isViewer();
      allow delete: if isAdmin();
    }
    match /feedbacks/{feedbackId} {
      allow create: if request.auth != null;
      allow read, delete: if isAdmin();
    }
    match /admin_flags/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /colaboradores/{docId} {
      allow read, write: if request.auth != null;
    }
    match /estoque_brindes/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /imob_patrimonio/{docId} { allow read, write: if isAdmin(); }
    match /imob_categorias/{docId} { allow read, write: if isAdmin(); }
    match /imob_localizacoes/{docId} { allow read, write: if isAdmin(); }
    match /imob_sublocalizacoes/{docId} { allow read, write: if isAdmin(); }
    match /imob_espacos/{docId} { allow read, write: if isAdmin(); }
    match /imob_contratos/{docId} { allow read, write: if isAdmin(); }
    match /imob_reconciliacoes/{docId} { allow read, write: if isAdmin(); }
    match /slack_conversas/{docId} { allow read, write: if isAdmin(); }
    match /slack_eventos_processados/{docId} { allow read, write: if isAdmin(); }
    match /slack_debug_logs/{docId} { allow read, write: if isAdmin(); }
    match /estoque_ti/{docId} { allow read, write: if isAdmin(); }
    match /estoque_onboarding/{docId} { allow read, write: if isAdmin(); }
    match /estoque_saidas/{docId} { allow read, write: if isAdmin(); }
    match /contadores/{docId} {
      allow read, write: if request.auth != null;
    }
    match /projetos_ia/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

{
  "version": 2,
  "functions": {
    "api/relatorio.js": {
      "maxDuration": 30
    },
    "api/slack-comando.js": {
      "maxDuration": 30
    },
    "api/slack-processar.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
